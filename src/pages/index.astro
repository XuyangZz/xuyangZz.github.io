---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout description={SITE.description}>
  <section class="intro">
    <h1>Hi, I'm Xuyang.</h1>
    <p>
      M.Eng. student at UESTC, working on multi-modal large models and embodied AI.
      I write here about research, learning, and the long road of figuring things out in public.
    </p>
  </section>

  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <h2><a href={`/posts/${post.slug}/`}>{post.data.title}</a></h2>
        <p class="post-meta">
          <time datetime={post.data.pubDatetime.toISOString()}>
            {fmt(post.data.pubDatetime)}
          </time>
          {post.data.tags.length > 0 && (
            <> · {post.data.tags.join(' · ')}</>
          )}
        </p>
        <p class="post-desc">{post.data.description}</p>
      </li>
    ))}
  </ul>
</BaseLayout>
